DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /Vince-Portfolio/

# Clean URLs for projects
RewriteRule ^projects/?$ projects.php [L]
RewriteRule ^project/([a-z0-9-]+)/?$ project.php?slug=$1 [L,QSA]
RewriteRule ^gallery/?$ gallery.php [L]
RewriteRule ^leadership/?$ leadership.php [L]
RewriteRule ^speaking/?$ speaking.php [L]
RewriteRule ^media/?$ media.php [L]
</IfModule>

<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType image/jpeg "access plus 1 month"
ExpiresByType image/png "access plus 1 month"
ExpiresByType image/webp "access plus 1 month"
ExpiresByType text/css "access plus 1 week"
ExpiresByType application/javascript "access plus 1 week"
</IfModule>
