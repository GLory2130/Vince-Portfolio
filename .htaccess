DirectoryIndex index.html

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /Vince-Portfolio/

# Clean URLs (static HTML)
RewriteRule ^projects/?$ projects.html [L]
RewriteRule ^project/([a-z0-9-]+)/?$ project.html?slug=$1 [L,QSA]
RewriteRule ^gallery/?$ gallery.html [L]
RewriteRule ^leadership/?$ leadership.html [L]
RewriteRule ^speaking/?$ speaking.html [L]
RewriteRule ^media/?$ media.html [L]
</IfModule>

<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType image/jpeg "access plus 1 month"
ExpiresByType image/png "access plus 1 month"
ExpiresByType image/webp "access plus 1 month"
ExpiresByType text/css "access plus 1 week"
ExpiresByType application/javascript "access plus 1 week"
</IfModule>
